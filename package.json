{
  "name": "live-agent",
  "version": "0.1.0-alpha.1",
  "description": "AI agent for Ableton Live — chat with GPT, Claude, or Gemini to control your session",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "node --import=tsx/esm scripts/generate-tools.ts"
  },
  "keywords": [
    "ableton",
    "live",
    "ai",
    "agent",
    "extension",
    "openai",
    "claude",
    "gemini"
  ],
  "license": "MIT",
  "dependencies": {
    "@ableton-extensions/sdk": "file:../extensions-sdk-1.0.0-beta.0/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.0",
    "openai": "^4.100.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.5",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
