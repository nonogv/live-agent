{
  "name": "live-agent",
  "version": "0.1.0-alpha.1",
  "description": "AI agent for Ableton Live — chat with GPT, Claude, or Gemini to control your session",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "prestart": "pkill -f ExtensionHostNodeModule.node || true",
    "start": "tsx build.ts && extensions-cli run",
    "typecheck": "tsc --noEmit",
    "generate": "node --import=tsx/esm scripts/generate-tools.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,html,scss}\"",
    "lint": "eslint --no-warn-ignored src/**/*.ts",
    "lint:fix": "eslint --no-warn-ignored src/**/*.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --check",
      "eslint"
    ],
    "src/**/*.{html,scss}": [
      "prettier --check"
    ]
  },
  "keywords": [
    "ableton",
    "live",
    "ai",
    "agent",
    "extension",
    "openai",
    "claude",
    "gemini"
  ],
  "license": "MIT",
  "dependencies": {
    "@ableton-extensions/sdk": "file:./vendor/ableton-extensions-sdk-1.0.0-beta.0.tgz",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:./vendor/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.12",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
