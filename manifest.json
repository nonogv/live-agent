{
  "name": "Live Agent",
  "id": "com.live-agent.extension",
  "version": "0.1.0",
  "description": "AI-powered assistant for Ableton Live. Chat with GPT, Claude, or Gemini to control your session using natural language.",
  "author": "Live Agent",
  "main": "dist/extension.js",
  "minLiveVersion": "12.4.5",
  "apiVersion": "1.0",
  "scopes": [
    "MidiTrack",
    "AudioTrack",
    "MidiClip",
    "AudioClip",
    "Scene",
    "ClipSlot",
    "DrumRack",
    "Simpler",
    "Sample"
  ],
  "contextMenuItems": [
    {
      "id": "open-live-agent",
      "label": "Open Live Agent",
      "scopes": ["MidiTrack", "AudioTrack", "Scene", "MidiClip", "AudioClip"]
    }
  ]
}
